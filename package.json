{
  "name": "stylish-front-end",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "loadsh": "^0.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-loading": "^2.0.3",
    "react-router-dom": "^6.4.0",
    "react-scripts": "5.0.1",
    "styled-components": "^5.3.5",
    "styled-reset": "^4.4.2"
  },
  "devDependencies": {
    "@mdx-js/react": "1.6.22",
    "@storybook/addon-actions": "^7.0.0-alpha.33",
    "@storybook/addon-docs": "^7.0.0-alpha.33",
    "@storybook/addon-essentials": "^7.0.0-alpha.33",
    "@storybook/addon-interactions": "^7.0.0-alpha.33",
    "@storybook/addon-links": "^7.0.0-alpha.33",
    "@storybook/builder-webpack5": "^7.0.0-alpha.33",
    "@storybook/manager-webpack5": "^7.0.0-alpha.10",
    "@storybook/node-logger": "^7.0.0-alpha.33",
    "@storybook/preset-create-react-app": "^4.1.2",
    "@storybook/react": "^7.0.0-alpha.33",
    "@storybook/react-webpack5": "^7.0.0-alpha.33",
    "@storybook/testing-library": "^0.0.13",
    "@types/react": "^18.0.20",
    "@types/react-dom": "^18.0.6",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.26",
    "babel-plugin-named-exports-order": "^0.0.2",
    "prop-types": "^15.8.1",
    "storybook": "^7.0.0-alpha.33",
    "typescript": "4.8.3",
    "webpack": "^5.74.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "storybook dev -p 6006 -s public",
    "build-storybook": "storybook build -s public"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
