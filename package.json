{
  "name": "stylish-front-end",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-loading": "^2.0.3",
    "react-router-dom": "^6.4.2",
    "react-scripts": "^5.0.1",
    "styled-components": "^6.0.0-beta.3",
    "styled-reset": "^4.4.2"
  },
  "devDependencies": {
    "@mdx-js/react": "^2.1.5",
    "@storybook/addon-essentials": "^7.0.0-alpha.41",
    "@storybook/addon-interactions": "^7.0.0-alpha.41",
    "@storybook/addon-links": "^7.0.0-alpha.41",
    "@storybook/builder-vite": "^7.0.0-alpha.41",
    "@storybook/mdx2-csf": "^0.0.4-canary.21ac716.0",
    "@storybook/react": "^7.0.0-alpha.41",
    "@storybook/react-vite": "^7.0.0-alpha.41",
    "@storybook/testing-library": "^0.0.13",
    "storybook": "^7.0.0-alpha.41",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.26",
    "typescript": "^4.8.4"
  },
  "overrides": {
    "@mdx-js/react": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@storybook/preset-create-react-app": {
      "@storybook/react": "$@storybook/react"
    },
    "styled-reset": {
      "styled-components": "$styled-components"
    }
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "sb dev -p 6006 -s public",
    "build-storybook": "sb build -s public"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
